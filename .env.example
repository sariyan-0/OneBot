# ===== ربات تلگرام =====
BOT_TOKEN=your_bot_token_from_botfather

# ===== پنل 3X-UI =====
# اگر پنل شما webBasePath دارد (Settings → Security → URI Path):
#   PANEL_URL=https://your-server.com:8443/ebHlkqXkBbjm2bI260
# اگر webBasePath ندارد:
#   PANEL_URL=https://your-server.com:54321
# ✗ غلط — /panel/api اضافه نکنید: https://your-server.com:54321/panel/api
PANEL_URL=https://your-server.com:8443/your-webBasePath
PANEL_USERNAME=admin
PANEL_PASSWORD=your_panel_password
# Preferred auth for newer 3X-UI panels:
# Settings -> Security -> API Token, then paste it here.
# If this is set, the bot uses Authorization: Bearer and skips username/password login.
# In API-token mode, PANEL_USERNAME and PANEL_PASSWORD can be left blank.
PANEL_API_TOKEN=
# PANEL_API_PATH=/panel/api  # پیش‌فرض — تغییر ندهید

# پورت لینک ساب (اختیاری)
# اگر پنل شما روی پورت متفاوتی subscription سرو می‌کند اینجا بنویسید.
# مثال: پنل روی 8443 ولی ساب روی 2096:
#   SUB_PORT=2096
# نتیجه: https://your-server.com:2096/sub/xxx
# اگر خالی بگذارید، همان پورت PANEL_URL استفاده می‌شود.
SUB_PORT=2096

# ===== دیتابیس =====
# SQLite (برای توسعه):
DB_URL=sqlite+aiosqlite:////data/bot_data.db
# PostgreSQL (برای production):
# DB_URL=postgresql+asyncpg://user:pass@localhost/dbname

# ===== ادمین‌ها =====
# آی‌دی عددی تلگرام ادمین‌ها (با ویرگول جدا کنید)
ADMIN_IDS=123456789,987654321

# رمز مخفی ورود به حالت ادمین — این رمز را به کسی ندهید!
# برای ورود: /admin_secret این_رمز
ADMIN_SECRET=your_secret_admin_password

# ===== پنل مدیریت وب =====
# بعد از اجرای ربات: http://YOUR_SERVER:9988/admin
WEB_ADMIN_ENABLED=false
WEB_ADMIN_USERNAME=admin
WEB_ADMIN_PASSWORD=your_web_admin_password
WEB_ADMIN_COOKIE_SECRET=change_this_random_secret

# ===== اشتراک پیش‌فرض =====
DEFAULT_SUBSCRIPTION_DAYS=30
DEFAULT_TRAFFIC_GB=0  # صفر = نامحدود

# ===== اشتراک تست رایگان =====
# این مقادیر پیش‌فرض هستند — ادمین می‌تواند از پنل ربات تغییر دهد
TEST_SUBSCRIPTION_ENABLED=true   # true = فعال | false = غیرفعال
TEST_TRAFFIC_GB=1                # حجم اشتراک تست (GB)
TEST_DURATION_DAYS=1             # مدت اشتراک تست (روز)

# ===== پرداخت کریپتو (NOWPayments) =====
# اگر خالی باشد، حالت sandbox/placeholder فعال می‌شود
# ادمین می‌تواند از پنل ادمین بین NOWPayments و MaxelPay سوئیچ کند
NOWPAYMENTS_API_KEY=your_nowpayments_api_key

# ── تأیید خودکار پرداخت (IPN Webhook) ──
# برای فعال کردن تأیید اتوماتیک:
#   1. در داشبورد NOWPayments → Settings → Payments → IPN Secret Key بسازید
#   2. همان key را اینجا وارد کنید
#   3. آدرس زیر را در NOWPayments → ipn_callback_url وارد کنید:
#      https://your-domain.com:8080/webhook/nowpayments
#   4. مطمئن شوید پورت 8080 روی سرور باز است
# اگر IPN_SECRET خالی باشد، کاربر باید دکمه «بررسی پرداخت» بزند
NOWPAYMENTS_IPN_SECRET=your_ipn_secret_key_from_dashboard
NOWPAYMENTS_IPN_URL=https://your-domain.com:9988/webhook/nowpayments
# فقط برای NOWPayments Direct coin؛ در Invoice page کاربر ارز را انتخاب می‌کند
NOWPAYMENTS_PAY_CURRENCY=usdttrc20  # USDT TRC-20
INVOICE_EXPIRE_MINUTES=30

# ── پورت webhook server ──
# پورت HTTP که ربات برای دریافت IPN از NOWPayments گوش می‌دهد
# پیش‌فرض 9988 — با 3X-UI (54321/8443) و nginx (80/443) تداخل ندارد
# اگه این پورت اشغال بود، هر عدد آزادی بذارید (مثلاً 7777 یا 9090)
# بررسی پورت آزاد روی سرور: ss -tlnp | grep 9988
# مهم: عدد پورت در IPN_URL بالا و WEBHOOK_PORT باید یکسان باشند
WEBHOOK_PORT=9988

# ===== پرداخت کریپتو (MaxelPay) =====
# ── MaxelPay یک درگاه کریپتو بدون KYC است (جایگزین یا مکمل NOWPayments)
# ── API Key از داشبورد: https://maxelpay.com
# ── مستندات API: https://docs.maxelpay.com
# اگر خالی باشد، MaxelPay غیرفعال است — از NOWPayments استفاده می‌شود
# ادمین می‌تواند از پنل ادمین → روش‌های پرداخت → درگاه بین دو سرویس سوئیچ کند
MAXELPAY_API_KEY=your_maxelpay_api_key

# آدرس webhook MaxelPay — باید HTTPS و قابل دسترس از اینترنت باشد
# MaxelPay بعد از هر پرداخت این URL را فراخوانی می‌کند (POST با JSON)
# ── همان پورت WEBHOOK_PORT می‌توان استفاده کرد (webhook_server.py هر دو را handle می‌کند)
# مثال: https://your-domain.com:9988/webhook/maxelpay
MAXELPAY_WEBHOOK_URL=https://your-domain.com/webhook/maxelpay

# کلید مخفی برای تأیید امضای webhook (X-MaxelPay-Signature header)
# از داشبورد MaxelPay → API Keys → Webhook Secret بگیرید
# اگه خالی باشد، بدون verify پرداخت فعال می‌شود (توصیه نمی‌شود)
MAXELPAY_WEBHOOK_SECRET=your_maxelpay_webhook_secret

# یوزرنیم ربات (بدون @) — برای لینک redirect بعد از پرداخت موفق/لغو در MaxelPay
# اختیاری: از BOT_TOKEN به صورت خودکار تشخیص داده می‌شود
BOT_USERNAME=

# ===== قیمت‌گذاری =====
PLAN_PRICE_USDT=5.0  # قیمت یک ماه اشتراک به دلار

# ===== نوتیفیکیشن و Scheduler =====
# ساعت اجرای check روزانه (UTC) — پیش‌فرض ۰۸:۰۰
# SCHEDULER_HOUR=8
# SCHEDULER_MINUTE=0

# ===== لاگ =====
LOG_LEVEL=INFO
LOG_FILE=logs/bot.log
