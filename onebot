#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
BOT_DIR="$(dirname "$SCRIPT_PATH")"

if [[ -x "$BOT_DIR/nexo-bot" ]]; then
  exec "$BOT_DIR/nexo-bot" "$@"
fi

if [[ -x "$BOT_DIR/install.sh" ]]; then
  exec "$BOT_DIR/install.sh" "$@"
fi

echo "onebot: missing launcher files in $BOT_DIR" >&2
exit 1
