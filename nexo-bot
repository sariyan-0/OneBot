#  [7] SSL Manager  —  Let's Encrypt via certbot
# ════════════════════════════════════════════════════════════

# ── helpers ──────────────────────────────────────────────────

_ssl_certbot_ok() {
  # reliable detection: PATH re-scan after install
  hash -r 2>/dev/null || true
  certbot --version &>/dev/null
}

_ssl_list_domains() {
  if [[ -d /etc/letsencrypt/live ]]; then
    local domains
    domains=$(ls /etc/letsencrypt/live/ 2>/dev/null | grep -v "^README$" || true)
    if [[ -n "$domains" ]]; then
      echo -e "\n  ${BOLD}Installed certificates:${RESET}"
      while IFS= read -r d; do
        [[ -z "$d" ]] && continue
        local cert="/etc/letsencrypt/live/$d/fullchain.pem"
        local exp="unknown"
        [[ -f "$cert" ]] && exp=$(openssl x509 -enddate -noout -in "$cert" 2>/dev/null \
                                  | sed 's/notAfter=//' || echo "unknown")
        echo -e "  ${GREEN}✔${RESET}  ${BOLD}$d${RESET}  ${DIM}(expires: $exp)${RESET}"
      done <<< "$domains"
    else
      echo -e "\n  ${DIM}No certificates found.${RESET}"
    fi
  else
    echo -e "\n  ${DIM}No certificates yet. Use [1] to get one.${RESET}"
  fi
}

_ssl_install_certbot() {
  if _ssl_certbot_ok; then
    _ok "certbot already installed: $(certbot --version 2>&1 | head -1)"
    return 0
  fi
  _info "Installing certbot..."
  if command -v apt-get &>/dev/null; then
    DEBIAN_FRONTEND=noninteractive apt-get install -y certbot \
      2>&1 | grep -E "^(Setting up|certbot|E:|error)" || true
  elif command -v dnf &>/dev/null; then
    dnf install -y certbot 2>&1 | tail -3 || true
  elif command -v yum &>/dev/null; then
    yum install -y certbot 2>&1 | tail -3 || true
  fi
  # re-scan PATH
  hash -r 2>/dev/null || true
  if ! _ssl_certbot_ok; then
    _info "Trying snap fallback..."
    snap install --classic certbot 2>/dev/null && \
      ln -sf /snap/bin/certbot /usr/bin/certbot 2>/dev/null || true
    hash -r 2>/dev/null || true
  fi
  if _ssl_certbot_ok; then
    _ok "certbot installed: $(certbot --version 2>&1 | head -1)"
    return 0
  fi
  _err "certbot install failed. Run manually: apt install certbot"
  return 1
}

_ssl_get_cert() {
  local domain="$1"
  local email="$2"

  echo ""
  _info "Preparing to obtain certificate for: ${BOLD}$domain${RESET}"

  # ── DNS check ────────────────────────────────────────────
  local server_ip domain_ip
  server_ip=$(curl -s --max-time 5 https://api.ipify.org 2>/dev/null \
              || curl -s --max-time 5 https://ifconfig.me 2>/dev/null \
              || echo "")
  domain_ip=$(getent hosts "$domain" 2>/dev/null | awk '{print $1}' | head -1 \
              || dig +short "$domain" 2>/dev/null | grep -v '\.$' | tail -1 \
              || echo "")

  if [[ -n "$server_ip" && -n "$domain_ip" ]]; then
    if [[ "$server_ip" == "$domain_ip" ]]; then
      _ok "DNS OK — $domain → $domain_ip"
    else
      echo ""
      _warn "DNS mismatch detected!"
      echo -e "  Server IP  : ${CYAN}$server_ip${RESET}"
      echo -e "  Domain IP  : ${YELLOW}$domain_ip${RESET}"
      _warn "$domain does not point to this server."
      _warn "Certificate issuance will likely fail."
      echo ""
      read -rp "  Continue anyway? (y/N): " _c
      [[ "$_c" =~ ^[Yy]$ ]] || return 1
    fi
  else
    _warn "Could not verify DNS (no IP detected). Proceeding..."
  fi

  # ── free port 80 if needed ───────────────────────────────
  local _stopped_nginx=false _stopped_apache=false
  if ss -tlnp 2>/dev/null | grep -q ':80 '; then
    _warn "Port 80 is in use — stopping service temporarily..."
    if systemctl is-active nginx  &>/dev/null; then
      systemctl stop nginx  && _stopped_nginx=true  && _info "nginx stopped."
    elif systemctl is-active apache2 &>/dev/null; then
      systemctl stop apache2 && _stopped_apache=true && _info "apache2 stopped."
    else
      _warn "Unknown service on port 80 — certbot may fail."
    fi
  fi

  # ── run certbot ──────────────────────────────────────────
  echo ""
  _info "Running certbot standalone..."
  echo -e "  ${DIM}──────────────────────────────────────────${RESET}"

  local cert_ok=false
  if certbot certonly \
      --standalone \
      --non-interactive \
      --agree-tos \
      --email "$email" \
      --domain "$domain" \
      --preferred-challenges http \
      2>&1 | while IFS= read -r line; do
        echo -e "  ${DIM}$line${RESET}"
      done; then
    cert_ok=true
  fi

  # re-check exit status (pipe loses it above — use temp file trick)
  if [[ -f "/etc/letsencrypt/live/$domain/fullchain.pem" ]]; then
    cert_ok=true
  fi

  echo -e "  ${DIM}──────────────────────────────────────────${RESET}"
  echo ""

  # ── restart stopped services ─────────────────────────────
  [[ "$_stopped_nginx"  == "true" ]] && systemctl start nginx   2>/dev/null && _info "nginx restarted." || true
  [[ "$_stopped_apache" == "true" ]] && systemctl start apache2 2>/dev/null && _info "apache2 restarted." || true

  if [[ "$cert_ok" == "true" ]]; then
    _ok "Certificate obtained for ${BOLD}$domain${RESET} ✓"
    return 0
  else
    _err "certbot failed. Check output above."
    _info "Common causes:"
    echo -e "  • Domain DNS not pointing to this server"
    echo -e "  • Port 80 blocked by firewall"
    echo -e "  • Rate limit hit (5 certs/domain/week)"
    return 1
  fi
}

_ssl_setup_nginx_proxy() {
  local domain="$1"
  local wh_port
  wh_port=$(grep "^WEBHOOK_PORT=" "$ENV_FILE" 2>/dev/null | cut -d= -f2 || echo "")
  wh_port="${wh_port:-9988}"

  if ! command -v nginx &>/dev/null; then
    _info "Installing nginx..."
    if command -v apt-get &>/dev/null; then
      DEBIAN_FRONTEND=noninteractive apt-get install -y nginx 2>&1 | tail -3 || true
    elif command -v dnf &>/dev/null; then
      dnf install -y nginx 2>&1 | tail -3 || true
    elif command -v yum &>/dev/null; then
      yum install -y nginx 2>&1 | tail -3 || true
    fi
    hash -r 2>/dev/null || true
  fi

  if ! command -v nginx &>/dev/null; then
    _warn "nginx not available — skipping proxy setup."
    _warn "Webhook will only be reachable on HTTP port $wh_port."
    return 1
  fi

  local conf_file="/etc/nginx/conf.d/onebot-webhook.conf"
  _info "Writing nginx config → $conf_file"
  cat > "$conf_file" <<NGINXCONF
# ONEBOT VPN Bot — Webhook HTTPS proxy
# Auto-generated by nexo-bot SSL Manager. Do not edit manually.

server {
    listen 80;
    server_name ${domain};
    # Let's Encrypt auto-renewal
    location /.well-known/acme-challenge/ { root /var/www/html; }
    location / { return 301 https://\$host\$request_uri; }
}

server {
    listen 443 ssl;
    server_name ${domain};

    ssl_certificate     /etc/letsencrypt/live/${domain}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/${domain}/privkey.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;
    ssl_session_cache   shared:SSL:10m;

    # Proxy only webhook paths to the bot
    location /webhook/ {
        proxy_pass         http://127.0.0.1:${wh_port};
        proxy_set_header   Host \$host;
        proxy_set_header   X-Real-IP \$remote_addr;
        proxy_read_timeout 15s;
    }
    location /health {
        proxy_pass http://127.0.0.1:${wh_port}/health;
    }
    location / { return 404; }
}
NGINXCONF

  if nginx -t 2>/dev/null; then
    systemctl enable nginx --now 2>/dev/null || true
    systemctl reload nginx 2>/dev/null || nginx -s reload 2>/dev/null || true
    _ok "nginx proxy configured → https://${domain}/webhook/"
    return 0
  else
    _err "nginx config test failed. Check: nginx -t"
    return 1
  fi
}

_ssl_update_env() {
  local domain="$1"
  local now_url="https://${domain}/webhook/nowpayments"
  local maxel_url="https://${domain}/webhook/maxelpay"

  echo ""
  echo -e "  ${BOLD}Webhook URLs for this domain:${RESET}"
  echo -e "  NOWPayments : ${CYAN}${now_url}${RESET}"
  echo -e "  MaxelPay    : ${CYAN}${maxel_url}${RESET}"
  echo ""
  read -rp "  Update .env automatically? (Y/n): " _yn
  _yn="${_yn:-Y}"
  [[ "$_yn" =~ ^[Yy]$ ]] || return 0

  _env_set "NOWPAYMENTS_IPN_URL"  "$now_url"
  _env_set "MAXELPAY_WEBHOOK_URL" "$maxel_url"
  _ok ".env updated."

  echo ""
  echo -e "  ${YELLOW}${BOLD}ACTION REQUIRED — Update your payment dashboards:${RESET}"
  echo -e "  ${BOLD}1. NOWPayments${RESET}  → Settings → IPN URL:"
  echo -e "     ${CYAN}${now_url}${RESET}"
  echo -e "  ${BOLD}2. MaxelPay${RESET}     → API Keys → Webhook URL:"
  echo -e "     ${CYAN}${maxel_url}${RESET}"
  echo ""
  read -rp "  Restart bot now to apply changes? (Y/n): " _ryn
  _ryn="${_ryn:-Y}"
  if [[ "$_ryn" =~ ^[Yy]$ ]]; then
    _require_compose && _dc up -d --force-recreate bot
    _ok "Bot restarted — new webhook URLs are active."
  fi
}

_env_set() {
  local key="$1"
  local val="$2"
  if grep -q "^${key}=" "$ENV_FILE" 2>/dev/null; then
    sed -i "s|^${key}=.*|${key}=${val}|" "$ENV_FILE"
  else
    echo "${key}=${val}" >> "$ENV_FILE"
  fi
}

_menu_update() {
  _banner
  echo -e "  ${BOLD}⬆️   Update ONEBOT${RESET}"
  _line
  if [[ -d "$BOT_DIR/.git" ]]; then
    _info "Pulling latest changes from git..."
    local _stashed=false
    if [[ -n "$(git -C "$BOT_DIR" status --porcelain 2>/dev/null || true)" ]]; then
      _warn "Local changes detected. Stashing them before update..."
      git -C "$BOT_DIR" stash push --include-untracked -m "onebot-auto-stash-$(date +%Y%m%d_%H%M%S)" >/dev/null 2>&1 || true
      _stashed=true
    fi

    git -C "$BOT_DIR" pull --rebase --autostash
    _info "Rebuilding bot image..."
    _dc build --no-cache bot
    _dc up -d --force-recreate bot
    if [[ -d "$BOT_DIR/web-panel" ]]; then
      _info "Rebuilding web panel..."
      cd "$BOT_DIR/web-panel"
      _ensure_swap_space
      _ensure_web_panel_dependencies
      npm run build
      _refresh_web_service
      systemctl restart onebot-web.service 2>/dev/null || true
      cd "$BOT_DIR"
    fi
    if [[ "$_stashed" == "true" ]]; then
      _info "Restoring local changes..."
      git -C "$BOT_DIR" stash pop >/dev/null 2>&1 || _warn "Could not fully restore stashed changes. Check git status."
    fi
    _ok "Update complete."
  else
    _warn "This install is not a git clone, so auto-update is unavailable."
    _info "Reinstall from the published GitHub source to enable update support."
  fi
  _press
}

_menu_admin_reset() {
  _banner
  echo -e "  ${BOLD}🔐  Reset Web Admin Login${RESET}"
  _line
  local new_user="admin"
  local new_pass
  new_pass="$(_rand_secret 12)"
  _env_set "WEB_ADMIN_ENABLED" "false"
  _env_set "WEB_ADMIN_USERNAME" "$new_user"
  _env_set "WEB_ADMIN_PASSWORD" "$new_pass"
  _env_set "WEB_ADMIN_COOKIE_SECRET" "$(_rand_secret 32)"
  _require_compose
  _dc up -d --force-recreate bot
  systemctl restart onebot-web.service 2>/dev/null || true
  echo ""
  _ok "Web admin login reset."
  echo -e "  Username: ${CYAN}${new_user}${RESET}"
  echo -e "  Password: ${CYAN}${new_pass}${RESET}"
  _warn "Store these now. They are written to .env and the bot has been recreated."
  _press
}

_menu_ssl() {
  while true; do
    _banner
    echo -e "  ${BOLD}🔒  SSL Manager — Let's Encrypt${RESET}"
    _line
    _ssl_list_domains
    echo ""
    echo -e "  ${BOLD}[1]${RESET}  Get new certificate      (domain / subdomain)"
    echo -e "  ${BOLD}[2]${RESET}  Renew all certificates   (certbot renew)"
    echo -e "  ${BOLD}[3]${RESET}  Show certificate details"
    echo -e "  ${BOLD}[0]${RESET}  ${DIM}Back${RESET}"
    _line
    read -rp "  Choose: " ch
    case $ch in
      1)
        echo ""
        echo -e "  ${BOLD}Domain or subdomain${RESET}  ${DIM}(e.g. pay.example.com)${RESET}"
        read -rp "  Domain: " _domain
        _domain="${_domain// /}"
        if [[ -z "$_domain" ]]; then
          _warn "Domain cannot be empty."; _press; continue
        fi

        # email — optional, auto-generate if skipped
        echo ""
        echo -e "  ${BOLD}Email for Let's Encrypt notifications${RESET}  ${DIM}(press Enter to skip)${RESET}"
        read -rp "  Email [optional]: " _email
        if [[ -z "$_email" ]]; then
          _email="noreply@${_domain}"
          _info "Using auto email: $_email"
        fi

        echo ""
        _ssl_install_certbot || { _press; continue; }
        _ssl_get_cert "$_domain" "$_email" || { _press; continue; }

        echo ""
        read -rp "  Setup nginx HTTPS proxy for webhooks? (Y/n): " _nyn
        _nyn="${_nyn:-Y}"
        if [[ "$_nyn" =~ ^[Yy]$ ]]; then
          _ssl_setup_nginx_proxy "$_domain"
        fi

        _ssl_update_env "$_domain"
        _press ;;

      2)
        _info "Renewing certificates..."
        if _ssl_certbot_ok; then
          if command -v nginx &>/dev/null && systemctl is-active nginx &>/dev/null; then
            certbot renew --nginx --quiet 2>&1 | tail -5 || \
              certbot renew --quiet 2>&1 | tail -5
          else
            certbot renew --standalone --quiet 2>&1 | tail -5
          fi
          _ok "Renewal complete."
        else
          _warn "certbot not installed. Use [1] to get your first certificate."
        fi
        _press ;;

      3)
        echo ""
        if _ssl_certbot_ok; then
          certbot certificates 2>/dev/null || _info "No certificates found."
        else
          _warn "certbot not installed."
        fi
        _press ;;

      0) return ;;
      *) _warn "Invalid option." ;;
    esac
  done
}

