_menu_control() {
  while true; do
    _banner
    echo -e "  ${BOLD}🤖  Bot Control${RESET}"
    _status_bar
    echo -e "  ${BOLD}[1]${RESET}  Start"
    echo -e "  ${BOLD}[2]${RESET}  Stop"
    echo -e "  ${BOLD}[3]${RESET}  Restart"
    echo -e "  ${BOLD}[4]${RESET}  Rebuild image + restart  (after code changes)"
    echo -e "  ${BOLD}[5]${RESET}  Live logs  (Ctrl+C to exit)"
    echo -e "  ${BOLD}[6]${RESET}  Last 100 lines of logs"
    echo -e "  ${BOLD}[0]${RESET}  ${DIM}Back${RESET}"
    _line
    read -rp "  Choose: " ch
    case $ch in
      1) _require_compose && _dc up -d && _ok "Bot started." && _press ;;
      2) _require_compose && _dc stop bot && _ok "Bot stopped." && _press ;;
      3) _require_compose
         _info "Recreating container to apply .env changes..."
         _dc up -d --force-recreate bot
         _ok "Restarted — .env changes applied." && _press ;;
      4) _require_compose
         _info "Rebuilding..."
         _dc build --no-cache bot
         _dc up -d --force-recreate bot
         _ok "Done." && _press ;;
      5) _require_compose && _dc logs -f bot ;;
      6) _require_compose && _dc logs --tail=100 bot && _press ;;
      0) return ;;
      *) _warn "Invalid option." ;;
    esac
  done
}

# ════════════════════════════════════════════════════════════
#  [2] Configuration
# ════════════════════════════════════════════════════════════
_menu_config() {
  while true; do
    _banner
    echo -e "  ${BOLD}⚙️   Configuration${RESET}"
    _line
    echo -e "  ${BOLD}[1]${RESET}  Edit .env               (main config)"
    echo -e "  ${BOLD}[2]${RESET}  View .env               (read-only)"
    echo -e "  ${BOLD}[3]${RESET}  Edit docker-compose.yml"
    echo -e "  ${BOLD}[4]${RESET}  Show key settings        (token hidden)"
    echo -e "  ${BOLD}[0]${RESET}  ${DIM}Back${RESET}"
    _line
    read -rp "  Choose: " ch
    case $ch in
      1)
        [[ ! -f "$ENV_FILE" ]] && cp "$BOT_DIR/.env.example" "$ENV_FILE" && _info "Created .env from example."
        ${EDITOR:-nano} "$ENV_FILE"
        echo ""
        _ok "Saved."
        _warn "Changes take effect ONLY after recreating the container (not just restart)."
        read -rp "  Apply changes now? Recreate container? (Y/n): " _yn
        _yn="${_yn:-Y}"
        if [[ "$_yn" =~ ^[Yy]$ ]]; then
          _require_compose
          _info "Recreating bot container with new .env..."
          _dc up -d --force-recreate bot
          _ok "Done — new .env is now active."
        else
          _info "Skipped. Run: onebot → Bot Control → [3] Restart  to apply later."
        fi
        _press ;;
      2)
        [[ -f "$ENV_FILE" ]] && { echo ""; cat "$ENV_FILE"; _press; } \
          || { _err ".env not found."; _press; } ;;
      3) ${EDITOR:-nano} "$COMPOSE_FILE" && _press ;;
      4)
        [[ -f "$ENV_FILE" ]] || { _err ".env not found."; _press; continue; }
        echo ""
        grep -E "^(BOT_TOKEN|PANEL_URL|PANEL_USERNAME|ADMIN_IDS|DB_URL|ADMIN_SECRET|USE_POSTGRES)" "$ENV_FILE" \
          | sed 's/\(BOT_TOKEN=\).*/\1***hidden***/' \
          | sed 's/\(ADMIN_SECRET=\).*/\1***hidden***/' \
          | while IFS= read -r line; do echo -e "  ${CYAN}$line${RESET}"; done
        _press ;;
      0) return ;;
      *) _warn "Invalid option." ;;
    esac
  done
}

