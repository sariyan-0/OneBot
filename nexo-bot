_webhook_show_current() {
  echo ""
  local now_url maxel_url wh_port
  now_url=$(grep   "^NOWPAYMENTS_IPN_URL="  "$ENV_FILE" 2>/dev/null | cut -d= -f2- || true)
  maxel_url=$(grep "^MAXELPAY_WEBHOOK_URL=" "$ENV_FILE" 2>/dev/null | cut -d= -f2- || true)
  wh_port=$(grep   "^WEBHOOK_PORT="         "$ENV_FILE" 2>/dev/null | cut -d= -f2  || true)
  echo -e "  ${BOLD}Current webhook configuration:${RESET}"
  echo -e "  NOWPayments  : ${CYAN}${now_url:-(not set)}${RESET}"
  echo -e "  MaxelPay     : ${CYAN}${maxel_url:-(not set)}${RESET}"
  echo -e "  Internal port: ${CYAN}${wh_port:-9988}${RESET}"
  echo ""
}

_webhook_pick_domain() {
  PICKED_DOMAIN=""
  local domains_arr=()
  if [[ -d /etc/letsencrypt/live ]]; then
    while IFS= read -r d; do
      [[ "$d" == "README" || -z "$d" ]] && continue
      domains_arr+=("$d")
    done < <(ls /etc/letsencrypt/live/ 2>/dev/null || true)
  fi

  if [[ ${#domains_arr[@]} -gt 0 ]]; then
    echo -e "\n  ${BOLD}Domains with SSL certificates:${RESET}"
    for i in "${!domains_arr[@]}"; do
      echo -e "  ${BOLD}[$((i+1))]${RESET}  ${domains_arr[$i]}"
    done
    echo -e "  ${BOLD}[m]${RESET}  Enter manually"
    echo ""
    read -rp "  Select: " _pick
    if [[ "$_pick" =~ ^[0-9]+$ ]] && (( _pick >= 1 && _pick <= ${#domains_arr[@]} )); then
      PICKED_DOMAIN="${domains_arr[$((_pick-1))]}"
    else
      read -rp "  Domain: " PICKED_DOMAIN
    fi
  else
    _warn "No SSL certificates found. Use SSL Manager [7] first."
    echo -e "  Or enter a domain manually (without SSL):"
    read -rp "  Domain: " PICKED_DOMAIN
  fi
  PICKED_DOMAIN="${PICKED_DOMAIN// /}"
}

_menu_webhook() {
  while true; do
    _banner
    echo -e "  ${BOLD}🔗  Webhook Manager${RESET}"
    _line
    _webhook_show_current
    echo -e "  ${BOLD}[1]${RESET}  Set webhook URLs from SSL domain"
    echo -e "  ${BOLD}[2]${RESET}  Set NOWPayments IPN URL manually"
    echo -e "  ${BOLD}[3]${RESET}  Set MaxelPay Webhook URL manually"
    echo -e "  ${BOLD}[4]${RESET}  Test webhook server  (/health check)"
    echo -e "  ${BOLD}[0]${RESET}  ${DIM}Back${RESET}"
    _line
    read -rp "  Choose: " ch
    case $ch in
      1)
        _webhook_pick_domain
        if [[ -n "$PICKED_DOMAIN" ]]; then
          _ssl_update_env "$PICKED_DOMAIN"
        fi
        _press ;;

      2)
        echo ""
        echo -e "  ${DIM}Example: https://pay.example.com/webhook/nowpayments${RESET}"
        read -rp "  NOWPayments IPN URL: " _url
        [[ -z "$_url" ]] && { _press; continue; }
        _env_set "NOWPAYMENTS_IPN_URL" "$_url"
        _ok "NOWPayments IPN URL updated."
        echo ""
        _warn "ACTION: Also update this in your NOWPayments dashboard → Settings → IPN URL"
        echo ""
        read -rp "  Restart bot now? (Y/n): " _r; _r="${_r:-Y}"
        [[ "$_r" =~ ^[Yy]$ ]] && _require_compose && \
          _dc up -d --force-recreate bot && _ok "Bot restarted."
        _press ;;

      3)
        echo ""
        echo -e "  ${DIM}Example: https://pay.example.com/webhook/maxelpay${RESET}"
        read -rp "  MaxelPay Webhook URL: " _url
        [[ -z "$_url" ]] && { _press; continue; }
        _env_set "MAXELPAY_WEBHOOK_URL" "$_url"
        _ok "MaxelPay Webhook URL updated."
        echo ""
        _warn "ACTION: Also update this in your MaxelPay dashboard → API Keys → Webhook URL"
        echo ""
        read -rp "  Restart bot now? (Y/n): " _r; _r="${_r:-Y}"
        [[ "$_r" =~ ^[Yy]$ ]] && _require_compose && \
          _dc up -d --force-recreate bot && _ok "Bot restarted."
        _press ;;

      4)
        local _port
        _port=$(grep "^WEBHOOK_PORT=" "$ENV_FILE" 2>/dev/null | cut -d= -f2 || echo "9988")
        _port="${_port:-9988}"
        echo ""
        _info "Testing webhook server on port ${_port}..."
        if curl -sf --max-time 5 "http://127.0.0.1:${_port}/health" &>/dev/null; then
          _ok "Webhook server is running  (http://127.0.0.1:${_port}/health) ✓"
        else
          _err "Webhook server is not responding."
          _info "Check logs: onebot → Bot Control → [5] Live logs"
        fi
        _press ;;

      0) return ;;
      *) _warn "Invalid option." ;;
    esac
  done
}

