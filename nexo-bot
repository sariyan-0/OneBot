_menu_uninstall() {
  _banner
  echo -e "  ${RED}${BOLD}⚠️   UNINSTALL — Complete Removal${RESET}"
  _line
  echo -e "  ${YELLOW}This will permanently delete:${RESET}"
  echo -e "  • Docker containers  (onebot_bot, onebot_postgres)"
  echo -e "  • Docker image       (onebot-vpn-bot)"
  echo -e "  • Docker volumes     (all data & logs)"
  echo -e "  • Bot directory      ($BOT_DIR)"
  echo -e "  • onebot command     (/usr/local/bin/onebot, /usr/local/bin/ONEBOT)"
  echo -e "  • nexo-bot command   (/usr/local/bin/nexo-bot)"
  echo -e "  • Web panel service   (onebot-web.service)"
  echo ""
  echo -e "  ${RED}${BOLD}THIS CANNOT BE UNDONE.${RESET}"
  _line
  read -rp "  Type  DELETE  to confirm: " confirm
  [[ "$confirm" != "DELETE" ]] && { _warn "Cancelled."; _press; return; }

  echo ""
  _info "Stopping containers..."
  docker compose -f "$COMPOSE_FILE" --profile postgres down -v --remove-orphans 2>/dev/null || true
  _info "Removing image..."
  docker rmi onebot-vpn-bot:latest 2>/dev/null || true
  _info "Removing bot directory..."
  rm -rf "$BOT_DIR"
  systemctl stop onebot-web.service 2>/dev/null || true
  systemctl disable onebot-web.service 2>/dev/null || true
  rm -f /etc/systemd/system/onebot-web.service
  systemctl daemon-reload 2>/dev/null || true
  _info "Removing nexo-bot command..."
  rm -f /usr/local/bin/onebot /usr/local/bin/ONEBOT
  rm -f /usr/local/bin/nexo-bot
  echo ""
  echo -e "  ${GREEN}${BOLD}✔  ONEBOT VPN Bot has been completely removed.${RESET}"
  echo ""
  exit 0
}

