_ensure_swap_space() {
  local mem_kb swap_kb swap_path="/swapfile" swap_size_mb=1024

  if [[ ! -r /proc/meminfo ]]; then
    return 0
  fi

  mem_kb="$(awk '/MemTotal:/ {print $2}' /proc/meminfo 2>/dev/null || echo 0)"
  swap_kb="$(awk '/SwapTotal:/ {print $2}' /proc/meminfo 2>/dev/null || echo 0)"

  if (( swap_kb >= 524288 )); then
    return 0
  fi

  if [[ -e "$swap_path" ]] && swapon --show=NAME --noheadings 2>/dev/null | awk '{print $1}' | grep -Fxq "$swap_path"; then
    return 0
  fi

  if ! command -v swapon &>/dev/null || ! command -v mkswap &>/dev/null; then
    _warn "Swap tools are missing; continuing without extra swap."
    return 0
  fi

  if (( mem_kb < 1200000 )); then
    swap_size_mb=2048
  fi

  _info "Creating ${swap_size_mb}MiB swap space to keep npm installs from being OOM-killed..."

  if ! fallocate -l "${swap_size_mb}M" "$swap_path" 2>/dev/null; then
    dd if=/dev/zero of="$swap_path" bs=1M count="$swap_size_mb" status=none
  fi

  chmod 600 "$swap_path"
  mkswap "$swap_path" >/dev/null
  swapon "$swap_path"

  if ! grep -qE "^[[:space:]]*${swap_path}[[:space:]]+none[[:space:]]+swap[[:space:]]" /etc/fstab 2>/dev/null; then
    printf '%s none swap sw 0 0\n' "$swap_path" >> /etc/fstab
  fi

  _ok "Swap ready at $swap_path"
}

_require_compose() {
  if [[ ! -f "$COMPOSE_FILE" ]]; then
    _err "docker-compose.yml not found in: $BOT_DIR"; _press; return 1
  fi
}

_status_bar() {
  local bot_status db_status db_mode web_status
  if docker ps --format '{{.Names}}' 2>/dev/null | grep -Eq "^(onebot_bot|nexora_bot)$"; then
    bot_status="${GREEN}● Running${RESET}"
  else
    bot_status="${RED}● Stopped${RESET}"
  fi
  if _use_postgres; then
    db_mode="PostgreSQL"
    if docker ps --format '{{.Names}}' 2>/dev/null | grep -Eq "^(onebot_postgres|nexora_postgres)$"; then
      db_status="${GREEN}● Running${RESET}"
    else
      db_status="${YELLOW}● Stopped${RESET}"
    fi
  else
    db_mode="SQLite"
    if [[ -f "$BOT_DB_PATH" ]]; then
      db_status="${GREEN}● file${RESET}"
    else
      db_status="${YELLOW}● missing${RESET}"
    fi
  fi
  if systemctl is-active onebot-web >/dev/null 2>&1; then
    web_status="${GREEN}● Running${RESET}"
  else
    web_status="${RED}● Stopped${RESET}"
  fi
  echo -e "  Bot: $bot_status    Web: $web_status    DB ($db_mode): $db_status"
  _line
}

_refresh_web_service() {
  local unit_file="/etc/systemd/system/onebot-web.service"
  local standalone_server="$BOT_DIR/web-panel/.next/standalone/server.js"
  local exec_start
  if [[ -f "$standalone_server" ]]; then
    exec_start="$(command -v node) $standalone_server"
  else
    exec_start="$(command -v npm) run start"
  fi

  cat > "$unit_file" <<EOF
[Unit]
Description=ONEBOT Next.js Admin Panel
After=network-online.target docker.service
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=$BOT_DIR/web-panel
Environment=NODE_ENV=production
Environment=ONEBOT_ROOT=$BOT_DIR
Environment=PORT=3000
Environment=HOST=127.0.0.1
Environment=HOSTNAME=127.0.0.1
EnvironmentFile=$ENV_FILE
ExecStart=$exec_start
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
EOF

  systemctl daemon-reload
  systemctl enable onebot-web.service >/dev/null 2>&1 || true

  local standalone_dir="$BOT_DIR/web-panel/.next/standalone"
  if [[ -d "$standalone_dir" ]]; then
    mkdir -p "$standalone_dir/.next"
    rm -rf "$standalone_dir/.next/static" "$standalone_dir/public" 2>/dev/null || true
    if [[ -d "$BOT_DIR/web-panel/.next/static" ]]; then
      cp -a "$BOT_DIR/web-panel/.next/static" "$standalone_dir/.next/" 2>/dev/null || true
    fi
    if [[ -d "$BOT_DIR/web-panel/public" ]]; then
      cp -a "$BOT_DIR/web-panel/public" "$standalone_dir/" 2>/dev/null || true
    fi
  fi
}

_web_panel_deps_stamp() {
  local lock_file="$BOT_DIR/web-panel/package-lock.json"
  local pkg_file="$BOT_DIR/web-panel/package.json"
  if [[ -f "$lock_file" ]] && [[ -f "$pkg_file" ]] && command -v sha256sum &>/dev/null; then
    sha256sum "$lock_file" "$pkg_file" | sha256sum | awk '{print $1}'
    return 0
  fi
  date +%s
}

_npm_arch() {
  case "$(uname -m)" in
    x86_64|amd64) printf 'x64' ;;
    aarch64|arm64) printf 'arm64' ;;
    armv7l) printf 'arm' ;;
    *) uname -m ;;
  esac
}

_ensure_web_panel_dependencies() {
  local deps_stamp
  deps_stamp="$(_web_panel_deps_stamp)"
  local stamp_file="$BOT_DIR/web-panel/node_modules/.onebot-web-deps.stamp"
  local npm_arch
  npm_arch="$(_npm_arch)"

  if [[ -f "$stamp_file" ]] && [[ "$(<"$stamp_file")" == "$deps_stamp" ]]; then
    return 0
  fi

  local npm_env=(env
    NPM_CONFIG_PROGRESS=false
    NPM_CONFIG_LOGLEVEL=warn
    npm_config_jobs=1
    npm_config_platform=linux
    npm_config_arch="$npm_arch"
    npm_config_libc=glibc
  )

  if [[ -f package-lock.json ]]; then
    if ! "${npm_env[@]}" npm ci --omit=dev --prefer-offline --no-fund --no-audit; then
      _err "Web panel dependency install failed."
      return 1
    fi
  else
    if ! "${npm_env[@]}" npm install --omit=dev --prefer-offline --no-fund --no-audit; then
      _err "Web panel dependency install failed."
      return 1
    fi
  fi

  if [[ ! -x node_modules/.bin/next ]]; then
    _err "Web panel dependencies are incomplete; next was not installed."
    return 1
  fi

  mkdir -p node_modules
  printf '%s\n' "$deps_stamp" > "$stamp_file"
}

