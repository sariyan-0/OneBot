_backup_ssl() {
  local ts; ts=$(date +%Y%m%d_%H%M)
    local dst="/root/onebot_ssl_backup_${ts}.tar.gz"
  if [[ ! -d /etc/letsencrypt ]]; then
    _warn "No SSL certificates found (/etc/letsencrypt does not exist)."
    return 1
  fi
  tar -czf "$dst" /etc/letsencrypt/ 2>/dev/null \
    && _ok "SSL certificates backed up: $dst" \
    || { _err "SSL backup failed."; return 1; }
}

_backup_env() {
  local ts; ts=$(date +%Y%m%d_%H%M)
    local dst="/root/onebot_env_backup_${ts}.env"
  if [[ ! -f "$ENV_FILE" ]]; then
    _warn ".env file not found."
    return 1
  fi
  cp "$ENV_FILE" "$dst" && chmod 600 "$dst" \
    && _ok ".env backed up: $dst" \
    || _err ".env backup failed."
}

_backup_nginx() {
  local ts; ts=$(date +%Y%m%d_%H%M)
  local conf="/etc/nginx/conf.d/onebot-webhook.conf"
  if [[ ! -f "$conf" ]]; then
    _info "No nginx config to backup (not set up yet)."
    return 0
  fi
    local dst="/root/onebot_nginx_backup_${ts}.conf"
  cp "$conf" "$dst" && _ok "nginx config backed up: $dst"
}

_backup_full() {
  local ts; ts=$(date +%Y%m%d_%H%M)
  _info "Starting full backup..."
  echo ""

  # 1 — Database
  if _use_postgres; then
    local dump="/root/onebot_pgdump_${ts}.sql"
    _require_compose
    _info "Backing up PostgreSQL..."
    _dc exec -T db pg_dump -U botuser vpn_bot > "$dump" \
      && _ok "Database: $dump" || _err "pg_dump failed."
  else
    local vol_path
    vol_path="$BOT_DB_PATH"
    if [[ -f "$vol_path" ]]; then
      local db_dst="/root/onebot_sqlite_${ts}.db"
      cp "$vol_path" "$db_dst" && _ok "Database (SQLite): $db_dst"
    else
      _warn "SQLite file not found at $BOT_DB_PATH."
    fi
  fi

  # 2 — SSL certificates
  _info "Backing up SSL certificates..."
  _backup_ssl

  # 3 — .env
  _info "Backing up .env..."
  _backup_env

  # 4 — nginx config
  _info "Backing up nginx config..."
  _backup_nginx

  echo ""
  _ok "Full backup complete. Files saved to /root/"
}

_menu_backup() {
  while true; do
    _banner
    echo -e "  ${BOLD}💾  Backup & Restore${RESET}"
    _line
    echo -e "  ${BOLD}[1]${RESET}  Full backup            (database + SSL certs + .env + nginx)"
    if _use_postgres; then
      echo -e "  ${BOLD}[2]${RESET}  Database only          (PostgreSQL dump)"
    else
      echo -e "  ${BOLD}[2]${RESET}  Database only          (SQLite copy)"
    fi
    echo -e "  ${BOLD}[3]${RESET}  SSL certificates only  (/etc/letsencrypt → tar.gz)"
    echo -e "  ${BOLD}[4]${RESET}  .env file only"
    echo -e "  ${BOLD}[5]${RESET}  List backup files"
    echo -e "  ${BOLD}[0]${RESET}  ${DIM}Back${RESET}"
    _line
    read -rp "  Choose: " ch
    case $ch in
      1) _backup_full; _press ;;

      2)
        if _use_postgres; then
          local dump="/root/onebot_pgdump_$(date +%Y%m%d_%H%M).sql"
          _require_compose
          _info "Dumping PostgreSQL to $dump ..."
          _dc exec -T db pg_dump -U botuser vpn_bot > "$dump" \
            && _ok "Saved: $dump" || _err "pg_dump failed."
        else
          local vol_path
          vol_path="$BOT_DB_PATH"
          if [[ -f "$vol_path" ]]; then
            local dst="/root/onebot_sqlite_$(date +%Y%m%d_%H%M).db"
            cp "$vol_path" "$dst" && _ok "Saved: $dst"
          else
            _warn "SQLite file not found at $BOT_DB_PATH."
          fi
        fi
        _press ;;

      3) _backup_ssl; _press ;;
      4) _backup_env; _press ;;

      5)
        echo ""
        echo -e "  ${BOLD}Backup files in /root/:${RESET}"
        ls -lh /root/onebot_*.db  2>/dev/null | awk '{print "  "$0}' || true
        ls -lh /root/onebot_*.sql 2>/dev/null | awk '{print "  "$0}' || true
        ls -lh /root/onebot_*.tar.gz 2>/dev/null | awk '{print "  "$0}' || true
        ls -lh /root/onebot_*.env 2>/dev/null | awk '{print "  "$0}' || true
        ls -lh /root/onebot_*.conf 2>/dev/null | awk '{print "  "$0}' || true
        _press ;;

      0) return ;;
      *) _warn "Invalid option." ;;
    esac
  done
}

